# ═══════════════════════════════════════════
#  ECOVE MARKETPLACE — ENVIRONMENT VARIABLES
#  Copy this to .env.local and fill in values
# ═══════════════════════════════════════════

# ── APP ──────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Ecove Marketplace"
NODE_ENV=development

# ── DATABASE (PostgreSQL) ─────────────────────
DATABASE_URL="postgresql://ecove_user:STRONGPASSWORD@localhost:5432/ecove_db?schema=public"

# ── AUTH ─────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars
JWT_EXPIRES_IN=7d

# ── CLOUDINARY (Image Uploads) ───────────────
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name

# ── PAYSTACK (Primary Payment) ───────────────
PAYSTACK_SECRET_KEY=your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=your_paystack_public_key
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=your_paystack_public_key
PAYSTACK_WEBHOOK_SECRET=your-paystack-webhook-secret

# ── FLUTTERWAVE (Secondary Payment) ──────────
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxx
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxx
FLUTTERWAVE_ENCRYPTION_KEY=your-flw-encryption-key
FLUTTERWAVE_WEBHOOK_SECRET=your-flw-webhook-secret

# ── EMAIL (Resend) ────────────────────────────
# Get your API key at https://resend.com — free tier: 3,000 emails/month
# Verify ecove.com.ng in your Resend dashboard before going live
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="Ecove Marketplace <noreply@ecove.com.ng>"
ADMIN_EMAIL=admin@ecove.com.ng

# ── REDIS (Required in production for rate limiting & webhook idempotency) ────
# Local: redis://localhost:6379
# Upstash (free tier): rediss://:<password>@<host>.upstash.io:6379
REDIS_URL=redis://localhost:6379

# ── ADMIN ────────────────────────────────────
SEED_ADMIN_EMAIL=admin@ecove.com.ng
SEED_ADMIN_PASSWORD=Admin@Ecove2025!

# ── RATE LIMITING ────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ── SENTRY (Error Monitoring) ─────────────────────────────
# Get your DSN from sentry.io — free tier is sufficient
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxx@oxxxxxxxx.ingest.sentry.io/xxxxxxxx
SENTRY_DSN=https://xxxxxxxx@oxxxxxxxx.ingest.sentry.io/xxxxxxxx
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=ecove-marketplace

# ── LOGGING ──────────────────────────────────────────────
LOG_LEVEL=info

# ── SEO ──────────────────────────────────────────────────
GOOGLE_SITE_VERIFICATION=your-google-search-console-verification-code

# ── PLAYWRIGHT E2E TESTS ──────────────────────────────────
# Base URL for Playwright (defaults to http://localhost:3000)
PLAYWRIGHT_BASE_URL=http://localhost:3000
# Admin credentials for E2E tests (use a test admin account, NOT production)
E2E_ADMIN_EMAIL=admin@ecove-test.com
E2E_ADMIN_PASSWORD=AdminTestPass123!
